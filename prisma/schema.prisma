// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MarketTechnicalSnapshot {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  source     String
  symbol     String
  snapshotAt DateTime @map("snapshot_at") @db.Timestamptz(6)
  closePrice Float?   @map("close_price")
  volume     BigInt?  @db.BigInt
  rsi        Float?
  macd       Float?
  macdSignal Float?   @map("macd_signal")
  ema20      Float?
  ema50      Float?
  rawPayload Json     @map("raw_payload")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([source, symbol, snapshotAt], map: "market_technical_snapshot_source_symbol_snapshot_at_key")
  @@index([symbol, snapshotAt], map: "market_technical_snapshot_symbol_snapshot_at_idx")
  @@map("market_technical_snapshot")
}

model MarketEventOfficial {
  id           BigInt    @id @default(autoincrement()) @db.BigInt
  source       String
  eventType    String    @map("event_type")
  dedupKey     String    @map("dedup_key")
  symbol       String?
  title        String
  eventDate    DateTime? @map("event_date") @db.Date
  referenceUrl String?   @map("reference_url")
  externalId   String?   @map("external_id")
  rawPayload   Json      @map("raw_payload")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([source, eventType, dedupKey], map: "market_event_official_source_event_type_dedup_key_key")
  @@index([eventType, eventDate], map: "market_event_official_event_type_event_date_idx")
  @@index([symbol], map: "market_event_official_symbol_idx")
  @@map("market_event_official")
}

model MarketSyncRunLog {
  id         BigInt    @id @default(autoincrement()) @db.BigInt
  source     String
  startedAt  DateTime  @map("started_at") @db.Timestamptz(6)
  finishedAt DateTime? @map("finished_at") @db.Timestamptz(6)
  status     String
  message    String
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([source, createdAt], map: "sync_run_log_source_created_at_idx")
  @@map("sync_run_log")
}

model MarketPriceHistory {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  source     String
  symbol     String
  timeframe  String
  priceAt    DateTime @map("price_at") @db.Timestamptz(6)
  openPrice  Float?   @map("open_price")
  highPrice  Float?   @map("high_price")
  lowPrice   Float?   @map("low_price")
  closePrice Float?   @map("close_price")
  volume     BigInt?  @db.BigInt
  rawPayload Json     @map("raw_payload")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([source, symbol, timeframe, priceAt], map: "market_price_history_source_symbol_timeframe_price_at_key")
  @@index([symbol, timeframe, priceAt], map: "market_price_history_symbol_timeframe_price_at_idx")
  @@map("market_price_history")
}
